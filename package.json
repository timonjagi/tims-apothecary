{
  "name": "tims-apothecary",
  "version": "1.0.0",
  "private": true,
  "description": "Tim's Apothecary — drop-shipped health remedies and supplements, powered by a Google Sheet as the database.",
  "author": "Tim",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "bunx rimraf packages/*/.next packages/*/dist packages/*/build packages/*/node_modules; bunx rimraf node_modules",
    "dev:medsy-modern": "bun --filter @medsy/modern dev",
    "dev:medsy-classic": "bun --filter @medsy/classic dev",
    "dev:medsy-minimal": "bun --filter @medsy/minimal dev",
    "build:medsy-modern": "bun --filter @medsy/modern build",
    "build:medsy-classic": "bun --filter @medsy/classic build",
    "build:medsy-minimal": "bun --filter @medsy/minimal build",
    "serve:medsy-modern": "bun --filter @medsy/modern start",
    "serve:medsy-classic": "bun --filter @medsy/classic start",
    "serve:medsy-minimal": "bun --filter @medsy/minimal start",
    "deploy-vercel:medsy-modern": "cd packages/medsy-modern && vercel --prod",
    "deploy-vercel:medsy-classic": "cd packages/medsy-classic && vercel --prod",
    "deploy-vercel:medsy-minimal": "cd packages/medsy-minimal && vercel --prod"
  },
  "devDependencies": {
    "cross-env": "^7.0.2",
    "husky": "^4.2.5",
    "lint-staged": "^10.3.0",
    "prettier": "^2.1.1",
    "rimraf": "^3.0.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,md,css}": [
      "prettier --trailing-comma es5 --single-quote --write"
    ]
  }
}
